NODE_ENV=development
PORT=3000
WEB_ORIGIN=http://127.0.0.1:5175
ASTRAOS_ALLOW_DEV_AUTH=false
ASTRAOS_JSON_LIMIT=1mb
ASTRAOS_REQUIRED_PROVIDERS=clerk,mongo,cloudinary,redis,openrouter
# Optional: append `reminders` only after a real reminder delivery provider and scheduler are configured.
# ASTRAOS_REQUIRED_PROVIDERS=clerk,mongo,cloudinary,redis,openrouter,reminders
ASTRAOS_OPS_TOKEN=
# Production requires ASTRAOS_OPS_TOKEN to be at least 32 characters.
ASTRAOS_TRUST_PROXY=true

CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

MONGODB_URI=
MONGODB_DB_NAME=astraos
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=0
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_SOCKET_TIMEOUT_MS=30000

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_MODEL_FALLBACKS=
OPENROUTER_MODELS=
OPENROUTER_TIMEOUT_MS=8000
OPENROUTER_CACHE_SECONDS=300
OPENROUTER_FAIL_CLOSED=false

# Provider Smoke / Release Gate
ASTRAOS_SMOKE_API_BASE_URL=http://127.0.0.1:3000/api
ASTRAOS_SMOKE_WEB_URL=http://127.0.0.1:5175
ASTRAOS_SMOKE_CORS_DENY_ORIGIN=https://blocked-origin.example
ASTRAOS_SMOKE_TARGET_ENV=development
ASTRAOS_SMOKE_BEARER_TOKEN=
ASTRAOS_SMOKE_CLERK_TOKEN=
ASTRAOS_SMOKE_USE_DEV_AUTH=false
ASTRAOS_SMOKE_DEV_USER=
ASTRAOS_SMOKE_OPS_TOKEN=
ASTRAOS_SMOKE_REQUIRE_READY=false
ASTRAOS_SMOKE_REQUIRE_OPENROUTER=false
ASTRAOS_SMOKE_FULL_CLOUDINARY=false
ASTRAOS_SMOKE_UPLOAD_FILE=
ASTRAOS_SMOKE_UPLOAD_CONTENT_TYPE=text/plain
ASTRAOS_SMOKE_TIMEOUT_MS=12000
ASTRAOS_SMOKE_REPORT_FILE=
