{
  "name": "@astraos/backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "audit:high": "npm audit --audit-level=high",
    "verify": "npm run typecheck && npm run test && npm run build",
    "db:sync-indexes": "tsx src/scripts/syncIndexes.ts",
    "smoke:providers": "tsx src/scripts/providerSmoke.ts"
  },
  "dependencies": {
    "@clerk/express": "^2.1.23",
    "@types/compression": "^1.8.1",
    "@upstash/redis": "^1.38.0",
    "cloudinary": "^2.7.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "mongoose": "^9.6.3",
    "morgan": "^1.10.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.12.3",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "~6.0.2",
    "vitest": "^4.1.8"
  }
}
