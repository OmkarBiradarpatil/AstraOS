# AstraOS Cloud Activation Environment
# Copy the relevant variables into apps/web/.env.local and backend/.env as needed.

# Frontend: Vercel / apps/web
VITE_API_BASE_URL=https://your-astraos-api.onrender.com/api
VITE_CLERK_PUBLISHABLE_KEY=replace_with_clerk_publishable_key
VITE_ASTRAOS_API_DEBUG=false

# Backend: Render / backend
NODE_ENV=production
PORT=3000
WEB_ORIGIN=https://your-astraos-web.vercel.app
ASTRAOS_ALLOW_DEV_AUTH=false
ASTRAOS_JSON_LIMIT=1mb
ASTRAOS_REQUIRED_PROVIDERS=clerk,mongo,cloudinary,redis,openrouter
# Optional: append `reminders` only after a real reminder delivery provider and scheduler are configured.
# ASTRAOS_REQUIRED_PROVIDERS=clerk,mongo,cloudinary,redis,openrouter,reminders
ASTRAOS_OPS_TOKEN=replace_with_32_plus_character_random_token
ASTRAOS_TRUST_PROXY=true

# Clerk
CLERK_SECRET_KEY=replace_with_clerk_secret_key
CLERK_PUBLISHABLE_KEY=replace_with_clerk_publishable_key
CLERK_WEBHOOK_SECRET=whsec_replace_me

# MongoDB Atlas
MONGODB_URI=replace_with_mongodb_atlas_connection_string
MONGODB_DB_NAME=astraos
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=0
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_SOCKET_TIMEOUT_MS=30000

# Cloudinary
CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://replace-me.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-replace_me
OPENROUTER_MODEL=openrouter/free
OPENROUTER_MODEL_FALLBACKS=
OPENROUTER_MODELS=
OPENROUTER_TIMEOUT_MS=8000
OPENROUTER_CACHE_SECONDS=300
OPENROUTER_FAIL_CLOSED=false

# Deployment Metadata
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=
RENDER_SERVICE_ID=

# Provider Smoke / Release Gate
ASTRAOS_SMOKE_API_BASE_URL=https://your-astraos-api.onrender.com/api
ASTRAOS_SMOKE_WEB_URL=https://your-astraos-web.vercel.app
ASTRAOS_SMOKE_CORS_DENY_ORIGIN=https://blocked-origin.example
ASTRAOS_SMOKE_TARGET_ENV=staging
ASTRAOS_SMOKE_BEARER_TOKEN=
ASTRAOS_SMOKE_CLERK_TOKEN=
ASTRAOS_SMOKE_USE_DEV_AUTH=false
ASTRAOS_SMOKE_DEV_USER=
ASTRAOS_SMOKE_OPS_TOKEN=
ASTRAOS_SMOKE_REQUIRE_READY=false
ASTRAOS_SMOKE_REQUIRE_OPENROUTER=false
ASTRAOS_SMOKE_FULL_CLOUDINARY=false
ASTRAOS_SMOKE_UPLOAD_FILE=
ASTRAOS_SMOKE_UPLOAD_CONTENT_TYPE=text/plain
ASTRAOS_SMOKE_TIMEOUT_MS=12000
ASTRAOS_SMOKE_REPORT_FILE=

# Optional Clerk E2E Lane
ASTRAOS_E2E_CLERK=false
ASTRAOS_E2E_CLERK_JWT=false
ASTRAOS_E2E_CLERK_SESSION_JWT=
